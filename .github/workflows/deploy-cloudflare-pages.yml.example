# Example workflow. Rename to deploy-cloudflare-pages.yml when the Cloudflare
# project and GitHub secrets are ready.
name: Deploy dashboards to Cloudflare Pages

on:
  workflow_dispatch:
  push:
    paths:
      - "input-workbooks/**"
      - "local_panel_app/**"
      - "scripts/**"
      - ".github/workflows/deploy-cloudflare-pages.yml"

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements-local.txt

      - name: Build static dashboards
        run: |
          python scripts/build_static_site.py --input input-workbooks --output dist

      - name: Deploy to Cloudflare Pages
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          command: pages deploy dist --project-name=${{ secrets.CLOUDFLARE_PROJECT_NAME }}
